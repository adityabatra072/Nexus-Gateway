{
  "name": "nexus-gateway",
  "version": "1.0.0",
  "description": "Production-ready API Gateway with JWT Authentication, Rate Limiting, and Microservice Routing",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "lint": "echo 'Linting...'",
    "docker:build": "docker build -t nexus-gateway .",
    "docker:run": "docker run -p 8080:8080 --env-file .env nexus-gateway"
  },
  "keywords": [
    "api-gateway",
    "microservices",
    "jwt",
    "authentication",
    "rate-limiting",
    "reverse-proxy",
    "express",
    "typescript",
    "docker",
    "security"
  ],
  "author": "Aditya Batra <adityabatra072@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adityabatra072/Nexus-Gateway.git"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
